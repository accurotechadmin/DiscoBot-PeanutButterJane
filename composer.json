{
    "name": "example/discordphp-bot-skeleton",
    "description": "A lightweight PHP CLI Discord bot skeleton powered by DiscordPHP.",
    "type": "project",
    "require": {
        "php": ">=8.1.2",
        "team-reflex/discord-php": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "bot": "php bin/bot.php",
        "sync-slash-commands": "php bin/sync-slash-commands.php",
        "lint": "find bin src config tests -name '*.php' -print0 | xargs -0 -n1 php -l",
        "test": "vendor/bin/phpunit",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
